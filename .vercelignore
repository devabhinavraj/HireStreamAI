# Exclude all local environments (wherever they are)
**/venv/
**/.venv/
**/backend/
.env
**/.env

# Exclude build artifacts and caches
**/.next/
**/node_modules/
**/__pycache__/
.turbo/

# Exclude large data or local uploads
**/uploads/
*.pdf
*.docx
*.bin
*.pt
*.h5
*.lib
*.dll

# Exclude documentation
docs/
server/docs/
client/docs/
