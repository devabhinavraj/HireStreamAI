{
  "version": 2,
  "buildCommand": "npm run build --prefix client",
  "installCommand": "npm install --prefix client",
  "outputDirectory": "client/.next",
  "framework": "nextjs",
  "functions": {
    "server/main.py": {
      "runtime": "@vercel/python"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "server/main.py"
    }
  ]
}
